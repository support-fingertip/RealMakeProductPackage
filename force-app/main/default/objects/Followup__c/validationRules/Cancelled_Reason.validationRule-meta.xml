<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancelled_Reason</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Cancelled&quot;),
    OR(
        ISBLANK(Cancelled_Reason__c),
        ISBLANK(Cancelled_Date__c)
    )
)</errorConditionFormula>
    <errorMessage>Please fill Cancelled Reason and Cancelled Date when Status is Cancelled.</errorMessage>
</ValidationRule>
