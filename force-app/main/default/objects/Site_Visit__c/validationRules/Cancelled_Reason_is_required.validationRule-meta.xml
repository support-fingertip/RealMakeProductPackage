<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancelled_Reason_is_required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Cancelled&quot;),
    ISBLANK(Cancelled_Reason__c)
)</errorConditionFormula>
    <errorMessage>Cancelled Reason is required when Status is Cancelled</errorMessage>
</ValidationRule>
