<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>completed_date_not_earlie_than_scheduled</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Completed_Date__c)),
    NOT(ISBLANK(Scheduled_Date__c)),
    Completed_Date__c &lt; Scheduled_Date__c
)</errorConditionFormula>
    <errorMessage>Completed Date cannot be earlier than Scheduled Date</errorMessage>
</ValidationRule>
