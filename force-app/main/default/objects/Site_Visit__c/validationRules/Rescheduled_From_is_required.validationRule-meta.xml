<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Rescheduled_From_is_required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Re-Schedule&quot;),
    ISBLANK(Rescheduled_From__c)
)</errorConditionFormula>
    <errorMessage>Rescheduled From is required when Status is Re-Schedule</errorMessage>
</ValidationRule>
