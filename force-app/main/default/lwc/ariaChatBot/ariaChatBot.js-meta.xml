<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Aria</masterLabel>
    <description>Conversational real-estate pre-sales assistant powered by Gemini. Qualifies leads, answers project/unit queries, schedules site visits and follow-ups, generates cost sheets.</description>
    <targets>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
        <target>lightning__Tab</target>
        <target>lightning__UtilityBar</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>Lead__c</object>
                <object>Booking__c</object>
                <object>Site_Visit__c</object>
                <object>Cost_Sheet__c</object>
                <object>Project__c</object>
                <object>Unit__c</object>
            </objects>
        </targetConfig>
        <targetConfig targets="lightning__UtilityBar">
            <property name="isInUtilityBar"
                      type="Boolean"
                      default="true"
                      label="Utility bar mode"
                      description="Hides the floating launcher and renders the chat inline so it fills the utility popup."/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>